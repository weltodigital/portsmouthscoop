# Portsmouth Scoop — environment variables
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# Variables WITHOUT the NEXT_PUBLIC_ prefix stay server-side only.

# --- Stripe (server-side) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email notifications (optional) ---
RESEND_API_KEY=        # optional, for form notifications
NOTIFY_EMAIL=          # optional, where form notifications go

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://portsmouthscoop.co.uk
